# ========================================
# 로컬 개발 환경 설정
# ========================================
# 이 파일을 `.env.local`로 복사하여 실제 값으로 채워주세요.

# Notion API 설정
# Integration 생성: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 데이터베이스 ID (32자)
# 데이터베이스 URL에서 확인 가능
# 예: https://www.notion.so/myworkspace/DATABASE_ID?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 애플리케이션 기본 URL (후기 상세 링크 생성에 사용)
# 로컬: http://localhost:3000
# 프로덕션: https://yourdomain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Next.js 환경
NODE_ENV=development

# ========================================
# 프로덕션 배포 (Vercel)
# ========================================
# Vercel 대시보드에서 환경 변수를 설정하세요.
#
# 1. Vercel Dashboard 접속: https://vercel.com/dashboard
# 2. 프로젝트 선택 → Settings → Environment Variables
# 3. 다음 변수 추가:
#    - NOTION_API_KEY: Notion Integration Token (secret_로 시작)
#    - NOTION_DATABASE_ID: 후기 데이터베이스 ID (32자)
#
# 환경별 설정:
# - Production: main 브랜치 배포 시 사용
# - Preview: PR 생성 시 사용 (선택적)
# - Development: 로컬 개발 시 .env.local 사용
